# Visualizations: Geographic
```{r}
# City
survey |>
  filter(!is.na(city)) |>
  count(city, sort = TRUE) |>
  ggplot(aes(x = n, y = fct_reorder(city, n))) +
  geom_col(fill = "#4a8fa8") +
  geom_text(aes(label = n), hjust = -0.2, size = 3.5) +
  labs(title = "Participants by City", x = "Count", y = NULL) +
  theme_minimal() +
  expand_limits(x = c(0, 35))

