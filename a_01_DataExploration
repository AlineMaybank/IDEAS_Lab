# Interactive Leaflet Map
```{r}
map_data <- survey |>
  filter(!is.na(latitude), !is.na(longitude)) |>
  mutate(
    popup_text = paste0(
      "<b>City:</b> ", city, "<br>",
      "<b>Province:</b> ", province, "<br>",
      "<b>Institution:</b> ", institution, "<br>",
      "<b>Accommodation:</b> ", accommodation_type, "<br>",
      "<b>Country of Origin:</b> ", country_of_origin, "<br>",
      "<b>Degree:</b> ", degree_currently_studying
    )
  )

city_palette <- colorFactor(palette = "Set2", domain = map_data$city)

leaflet(map_data) |>
  addProviderTiles(providers$CartoDB.Positron) |>
  addCircleMarkers(
    lng         = ~longitude,
    lat         = ~latitude,
    color       = ~city_palette(city),
    radius      = 7,
    stroke      = FALSE,
    fillOpacity = 0.8,
    popup       = ~popup_text
  ) |>
  addLegend(
    position = "bottomright",
    pal      = city_palette,
    values   = ~city,
    title    = "City"
  ) |>
  setView(lng = -80.5, lat = 43.5, zoom = 7)
```

