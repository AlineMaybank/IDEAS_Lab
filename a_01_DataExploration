```

# Visualizations: Socio-Demographics
```{r}
# Country of origin — pie chart
country_counts <- survey |>
  filter(!is.na(country_of_origin)) |>
  count(country_of_origin, sort = TRUE) |>
  mutate(
    pct   = round(n / sum(n) * 100, 1),
    label = if_else(pct >= 4, paste0(country_of_origin, "\n", pct, "%"), "")
  )

ggplot(country_counts, aes(x = "", y = n, fill = country_of_origin)) +
  geom_col(width = 1, colour = "white") +
  coord_polar(theta = "y") +
  geom_text(aes(label = label),
            position = position_stack(vjust = 0.5), size = 3) +
  labs(title = "Country of Origin", fill = "Country") +
  theme_void()

