Purpose: the purpose of this script is to explore the data available through the IDEAS Lab excel document: Qualtrics Survey_Cleaned_Feb172026.xlsx

# Packages
```{r, message=FALSE, warning=FALSE}
library(tidyverse)
library(readxl)
library(janitor)
library(ggplot2)
library(leaflet)
library(sf)
library(knitr)
library(kableExtra)
```

# Read in Qualtrics Dataset
```{r}
survey_raw <- read_excel("Qualtrics_Survey_Cleaned_Feb172026_47rows.xlsx", sheet = 1) |>
  clean_names()
```

# Explore Raw Structure
```{r}
dim(survey_raw)
colnames(survey_raw)
glimpse(survey_raw)
```

# Save Codebook from Row 1 Labels
```{r}
question_labels <- survey_raw |>
  slice(1) |>
  pivot_longer(everything(), names_to = "col_code", values_to = "question_text")

write_csv(question_labels, "codebook_question_labels.csv")
```

# Clean & Rename
```{r}
survey <- survey_raw |>
  slice(-1) |>
  rename(
    name                      = qid57,
    institution               = qid10,
    country_of_origin         = q1,
    ethnic_origin             = q2,
    ethnic_origin_other       = q2a,
    language_home             = q3,
    sexual_orientation        = q4,
    sexual_orientation_other  = q4a,
    gender_identity           = q5,
    gender_identity_other     = q5a,
    age                       = q6,
    year_immigrated           = q7,
    duration_in_province      = q8,
    current_address           = q9,
    postal_code               = q9_1,
    city                      = q9_2,
    province                  = q9_3,
    latitude                  = q9_4,
    longitude                 = q9_5,
    accommodation_type        = q10,
    accommodation_other       = q10a,
    duration_current_address  = q11,
    first_address_canada      = q12,
    direct_from_home_country  = q13,
    country_before_canada     = q14,
    marital_status            = q15,
    education_outside_canada  = q16,
    education_outside_other   = q16a,
    country_education_outside = q17,
    field_outside_canada      = q18,
    field_in_canada           = q19,
    education_in_canada       = q20,
    education_in_canada_other = q20a,
    degree_currently_studying = q21,
    degree_other              = q21a,
    monthly_income            = q22
  ) |>
  mutate(
    age             = as.numeric(age),
    latitude        = as.numeric(latitude),
    longitude       = as.numeric(longitude),
    # coerce year — free text entries like "2013, 2017, 2023" become NA
    year_immigrated = as.numeric(year_immigrated),
    year_immigrated = if_else(year_immigrated < 1990, NA_real_, year_immigrated)
  )

glimpse(survey)
nrow(survey)  # should be 45
```

# Fix Encoding
```{r}
survey <- survey |>
  mutate(across(where(is.character), \(x) {
    x |>
      str_replace_all("\u00e2\u0080\u0099", "'")  |>  # curly apostrophe
      str_replace_all("\u00e2\u0080\u0093", "\u2013") |>  # en-dash
      str_replace_all("\u00e2\u0080\u009c", "\u201c") |>  # left quote
      str_replace_all("\u00e2\u0080\u009d", "\u201d")     # right quote
  }))

# Spot check
survey |> distinct(education_in_canada) |> kable()
survey |> distinct(monthly_income) |> kable()
survey |> distinct(accommodation_type) |> kable()
```

# Completeness
```{r}
survey |>
  summarise(across(everything(), \(x) sum(is.na(x)))) |>
  pivot_longer(everything(), names_to = "variable", values_to = "n_missing") |>
  mutate(pct_missing = round(n_missing / nrow(survey) * 100, 1)) |>
  arrange(desc(n_missing)) |>
  kable(caption = "Missing Data Summary") |>
  kable_styling(bootstrap_options = c("striped", "hover"))
```

